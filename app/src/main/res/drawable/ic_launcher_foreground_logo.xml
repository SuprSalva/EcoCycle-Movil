<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive icon foreground para EcoCycle.
    El canvas es 108x108dp pero la zona segura visible es el círculo central de ~66dp.
    El bitmap del logo se coloca centrado con margen de 22dp por lado (108 - 2*22 = 64dp de logo).
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="22dp"
        android:top="22dp"
        android:right="22dp"
        android:bottom="22dp"
        android:drawable="@drawable/logo_transparent" />
</layer-list>
