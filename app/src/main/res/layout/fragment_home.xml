<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:clipToPadding="false">

        <!-- TopAppBar Area (Optional if handled by Activity, but we'll include the welcome text here) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hola, Carlos! 👋"
                android:textColor="@color/on_surface"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="@font/quicksand"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Listo para seguir salvando el planeta hoy?"
                android:textColor="@color/on_surface_variant"
                android:textSize="16sp"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/nunito_sans"/>
        </LinearLayout>

        <!-- Balance Card (Bento Style) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/primary_container"
            app:cardCornerRadius="28dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp"
            android:layout_marginBottom="16dp">
            
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <!-- Decorative Blob could go here using an ImageView -->

                <LinearLayout
                    android:id="@+id/llBalanceHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent">
                    
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_history"
                        app:tint="@color/on_primary_container"
                        android:alpha="0.9"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Saldo Disponible"
                        android:textColor="@color/on_primary_container"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginStart="8dp"
                        android:alpha="0.9"
                        android:fontFamily="@font/nunito_sans"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llBalanceAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/llBalanceHeader"
                    app:layout_constraintStart_toStartOf="parent">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2,450"
                        android:textColor="@color/on_primary_container"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/quicksand"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" pts"
                        android:textColor="@color/on_primary_container"
                        android:textSize="16sp"
                        android:paddingBottom="4dp"
                        android:alpha="0.8"
                        android:fontFamily="@font/nunito_sans"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCanjear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Canjear"
                    android:textColor="@color/primary_container"
                    android:textSize="14sp"
                    android:fontFamily="@font/nunito_sans"
                    app:backgroundTint="@color/on_primary_container"
                    app:cornerRadius="20dp"
                    app:icon="@drawable/ic_rewards"
                    app:iconTint="@color/primary_container"
                    app:iconGravity="end"
                    android:layout_marginTop="16dp"
                    app:layout_constraintTop_toBottomOf="@id/llBalanceAmount"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Stats Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_container_lowest"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_circle_secondary_container"
                    android:layout_marginBottom="12dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_recycling"
                        app:tint="@color/on_secondary_container"/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="128"
                    android:textColor="@color/on_surface"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/quicksand"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total de botellas recicladas"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/nunito_sans"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical">
                    
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Meta mensual"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp"
                        android:fontFamily="@font/nunito_sans"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="128 / 200"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp"
                        android:fontFamily="@font/nunito_sans"/>
                </LinearLayout>

                <ProgressBar
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="8dp"
                    android:progress="64"
                    android:progressDrawable="@drawable/bg_progress_bar" />
                    
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Recent Activity -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Actividad Reciente"
                android:textColor="@color/on_surface"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="@font/quicksand"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ver todo"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/nunito_sans"/>
        </LinearLayout>

        <!-- Activity Items -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Item 1 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">
                    
                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle_secondary_container">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_water_drop"
                            app:tint="@color/on_secondary_container"/>
                    </FrameLayout>
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginHorizontal="16dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3 botellas"
                            android:textColor="@color/on_surface"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/nunito_sans"/>
                            
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ayer • Kiosco Plaza"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp"
                            android:fontFamily="@font/nunito_sans"/>
                    </LinearLayout>
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+150 pts"
                        android:textColor="@color/primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_sans"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Item 2 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">
                    
                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle_surface_variant">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_redeem"
                            app:tint="@color/on_surface_variant"/>
                    </FrameLayout>
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginHorizontal="16dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Descuento Café"
                            android:textColor="@color/on_surface"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/nunito_sans"/>
                            
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10 Oct • Canje"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp"
                            android:fontFamily="@font/nunito_sans"/>
                    </LinearLayout>
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-500 pts"
                        android:textColor="@color/error"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_sans"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
