<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:clipToPadding="false">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Recompensas"
                android:textColor="@color/on_surface"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="@font/quicksand"/>
        </LinearLayout>

        <!-- Points Summary Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/primary"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="24dp">
            
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">
                
                <TextView
                    android:id="@+id/tvPointsLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Puntos Disponibles"
                    android:textColor="@color/on_primary"
                    android:textSize="14sp"
                    android:alpha="0.8"
                    android:fontFamily="@font/nunito_sans"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>
                    
                <TextView
                    android:id="@+id/tvPointsValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2,450"
                    android:textColor="@color/on_primary"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/quicksand"
                    app:layout_constraintTop_toBottomOf="@id/tvPointsLabel"
                    app:layout_constraintStart_toStartOf="parent"/>
                    
                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_circle_surface_container"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_redeem"
                        app:tint="@color/primary"/>
                </FrameLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>
        
        <!-- Category Filter -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="24dp">
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Todos"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:checked="true"
                    app:chipBackgroundColor="@color/primary_container"
                    android:textColor="@color/on_primary_container"
                    android:layout_marginEnd="8dp"/>
                    
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Comida"
                    style="@style/Widget.Material3.Chip.Filter"
                    app:chipBackgroundColor="@color/surface_container_low"
                    android:layout_marginEnd="8dp"/>
                    
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Transporte"
                    style="@style/Widget.Material3.Chip.Filter"
                    app:chipBackgroundColor="@color/surface_container_low"
                    android:layout_marginEnd="8dp"/>
                    
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Donaciones"
                    style="@style/Widget.Material3.Chip.Filter"
                    app:chipBackgroundColor="@color/surface_container_low"/>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Rewards Grid (Using LinearLayouts to simulate columns for simplicity) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:baselineAligned="false"
            android:layout_marginBottom="16dp">
            
            <!-- Item 1 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/surface_variant"
                app:strokeWidth="1dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_circle_secondary_container"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_coffee"
                            app:tint="@color/on_secondary_container"/>
                    </FrameLayout>
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Café Americano"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_sans"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Starbucks"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/nunito_sans"/>
                        
                    <com.google.android.material.button.MaterialButton
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="500 pts"
                        android:textSize="12sp"
                        android:layout_marginTop="16dp"
                        app:backgroundTint="@color/primary"
                        app:cornerRadius="16dp"
                        android:fontFamily="@font/nunito_sans"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            
            <!-- Item 2 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/surface_variant"
                app:strokeWidth="1dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_circle_surface_variant"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_discount"
                            app:tint="@color/on_surface_variant"/>
                    </FrameLayout>
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Viaje 50% Off"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_sans"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Uber"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/nunito_sans"/>
                        
                    <com.google.android.material.button.MaterialButton
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="800 pts"
                        android:textSize="12sp"
                        android:layout_marginTop="16dp"
                        app:backgroundTint="@color/primary"
                        app:cornerRadius="16dp"
                        android:fontFamily="@font/nunito_sans"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
        
        <!-- Rewards Grid Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:baselineAligned="false">
            
            <!-- Item 3 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/surface_variant"
                app:strokeWidth="1dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_circle_secondary_container"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_fastfood"
                            app:tint="@color/on_secondary_container"/>
                    </FrameLayout>
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hamburguesa"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_sans"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Burger King"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/nunito_sans"/>
                        
                    <com.google.android.material.button.MaterialButton
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1200 pts"
                        android:textSize="12sp"
                        android:layout_marginTop="16dp"
                        app:backgroundTint="@color/primary"
                        app:cornerRadius="16dp"
                        android:fontFamily="@font/nunito_sans"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            
            <!-- Item 4 (Disabled/Not enough points state) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/surface_variant"
                app:strokeWidth="1dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_circle_surface_variant"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_card_giftcard"
                            app:tint="@color/on_surface_variant"/>
                    </FrameLayout>
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bono $200"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_sans"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Amazon"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/nunito_sans"/>
                        
                    <com.google.android.material.button.MaterialButton
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="3000 pts"
                        android:textSize="12sp"
                        android:layout_marginTop="16dp"
                        app:backgroundTint="@color/surface_variant"
                        android:textColor="@color/on_surface_variant"
                        app:cornerRadius="16dp"
                        android:fontFamily="@font/nunito_sans"
                        android:enabled="false"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
